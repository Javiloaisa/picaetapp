# Copia este fichero a .env y rellena los valores. NO subas .env al repo.

# Contraseña de la base de datos (invéntate una larga).
DB_PASSWORD=pon-una-contraseña-larga-aqui

# Clave para firmar las cookies de sesión. Genera una con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=pega-aqui-una-clave-larga-y-aleatoria

# Dirección pública del sitio (la usa Caddy para el HTTPS automático).
# Sin dominio propio: usa sslip.io con la IP de tu servidor cambiando los
# puntos por guiones. Ej. si tu IP es 203.0.113.5 ->
#   SITE_ADDRESS=203-0-113-5.sslip.io
# El día que tengas dominio: SITE_ADDRESS=picadita.tudominio.com
SITE_ADDRESS=TU-IP-CON-GUIONES.sslip.io

# Cookie solo por HTTPS. Déjalo en 1 en producción (hay HTTPS vía Caddy).
# Ponlo a 0 solo si sirves por HTTP puro (p. ej. pruebas en local).
COOKIE_SECURE=1
