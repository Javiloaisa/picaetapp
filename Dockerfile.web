# Imagen web: compila el frontend y lo sirve con Caddy (que además hace de
# reverse proxy hacia la API y gestiona el HTTPS automático).

# --- 1) Build del frontend estático ---
FROM node:22-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# --- 2) Caddy sirviendo /srv y proxeando /api ---
FROM caddy:2-alpine
COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
